.vercel

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Local wardrobe assets ───────────────────────────────────────────────────
# Raw clothing images live on-device, not in the repo (large binary files)
WearWise Clothes/

# ─── Dev / agent logs ────────────────────────────────────────────────────────
codex-logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Local agent / AI notes ──────────────────────────────────────────────────
