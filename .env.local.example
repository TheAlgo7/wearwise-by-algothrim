# WearWise environment variables
# Copy this file to `.env.local` and fill in your own values.

# ── Required ─────────────────────────────────────────────────────────────────

# Supabase — https://supabase.com  (Project Settings → API)
# IMPORTANT: SUPABASE_SERVICE_ROLE_KEY must be the *service_role* secret key,
# NOT the anon key. All DB writes go through API routes that rely on it —
# with the anon key here, every write fails against RLS (anon is read-only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenWeather — https://openweathermap.org/api  (free tier, 1000 calls/day)
OPENWEATHER_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey  (free tier)
# Used for: image tagging (multimodal), image cleanup, and as the final
# fallback in the outfit generation chain (Groq → OpenRouter → Gemini).
GEMINI_API_KEY=

# ── Optional — outfit generation chain ───────────────────────────────────────
# The /api/generate route tries these providers in order (fastest first).
# Omit any you don't have — the chain falls back gracefully.

# Groq — https://console.groq.com  (free tier, very fast inference)
# Model used: llama-3.3-70b-versatile
GROQ_API_KEY=

# OpenRouter — https://openrouter.ai  (free-tier fallback models)
# Models tried: openai/gpt-oss-120b:free, meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_KEY=

# ── Optional — access gate ────────────────────────────────────────────────────
# When set, the whole app (pages + API) requires this PIN once per device.
# Leave unset for open local dev. Set it in Vercel to lock the public URL.
APP_PIN=

# ── Optional — location ───────────────────────────────────────────────────────
# Default city fallback when GPS is denied (format: "City,Country")
NEXT_PUBLIC_DEFAULT_CITY=New Delhi,IN
